# Copia este archivo como .env y ajusta los valores
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/consulta_placas
CACHE_TTL_MINUTOS=30

# Fase 2 — auth JWT. Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=cambiar_por_clave_segura_de_al_menos_64_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRA_MINUTOS=1440

# CORS — orígenes permitidos (coma-separados). En prod incluir URL del frontend.
CORS_ORIGINS=http://localhost:3000

# Deployment (Render asigna PORT automáticamente; HOST=0.0.0.0 en prod).
# HOST=0.0.0.0
# PORT=10000
