# Copia este archivo como .env y ajusta los valores
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/consulta_placas
# Caché de fuentes (TTL de doble velocidad, ver services/cache.py).
# CACHE_TTL_MINUTOS es el fallback para fuentes sin clasificar.
CACHE_TTL_MINUTOS=30
# Datos transaccionales (multas, infracciones, denuncias, valores): TTL corto.
CACHE_TTL_TRANSACCIONAL_MINUTOS=720
# Datos estáticos (características del vehículo): TTL largo (reservado para el TO-BE).
CACHE_TTL_ESTATICO_MINUTOS=129600

# Fase 2 — auth JWT. Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=cambiar_por_clave_segura_de_al_menos_64_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRA_MINUTOS=1440

# CORS — orígenes permitidos (coma-separados). En prod incluir URL del frontend.
CORS_ORIGINS=http://localhost:3000

# Fase 5 — OCR de placas. API key de Google Cloud Vision (REST images:annotate).
# Sin esta clave, POST /consultar-foto responde 503 "OCR no configurado".
GOOGLE_VISION_API_KEY=

# Anti-captcha para SRI (proveedor: 2Captcha). API key de la cuenta fondeada.
# Sin esta clave, el solver queda DESHABILITADO y SRI sigue devolviendo
# bloqueado_captcha (comportamiento previo, sin cambios). Ver services/captcha.py.
TWOCAPTCHA_API_KEY=

# Extracción en la nube vía Apify (render + rotación de IP) para fuentes que bloquean
# IPs de datacenter. Sin este token, ApifyExtractor.obtener_datos() lanza error y la
# feature queda deshabilitada (no rompe el resto). Ver services/extractor_apify.py.
# Token de la cuenta Apify: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Proxy residencial para Playwright (egreso IP residencial EC). Permite que AMT/EPMTSD/FGE
# funcionen desde la nube sin máquina residencial propia. Sin ninguna de estas vars, el
# scraping va directo (comportamiento actual). REQUIERE proxy RESIDENCIAL real (datacenter
# NO sirve). Ver src/core/proxy_apify.py.
#
# Opción A (recomendada) — cualquier proveedor, URL completa:
#   SCRAPER_PROXY_URL=http://usuario:password@host:puerto
SCRAPER_PROXY_URL=
# Opción B — Apify por componentes. OJO: el plan Apify FREE NO incluye residencial
# (solo datacenter, que estas fuentes bloquean) → requiere plan Apify de pago.
# La password NO es el API token: está en Apify Console → Proxy.
APIFY_PROXY_PASSWORD=
APIFY_PROXY_GROUPS=RESIDENTIAL
APIFY_PROXY_PAIS=EC

# Deployment (Render asigna PORT automáticamente; HOST=0.0.0.0 en prod).
# HOST=0.0.0.0
# PORT=10000
