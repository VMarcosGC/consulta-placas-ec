# Copia este archivo como .env y ajusta los valores
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/consulta_placas
CACHE_TTL_MINUTOS=30

# Fase 2 — auth JWT. Generar con: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=cambiar_por_clave_segura_de_al_menos_64_caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRA_MINUTOS=1440

# CORS — orígenes permitidos (coma-separados). En prod incluir URL del frontend.
CORS_ORIGINS=http://localhost:3000

# Fase 5 — OCR de placas. API key de Google Cloud Vision (REST images:annotate).
# Sin esta clave, POST /consultar-foto responde 503 "OCR no configurado".
GOOGLE_VISION_API_KEY=

# Anti-captcha para SRI (proveedor: 2Captcha). API key de la cuenta fondeada.
# Sin esta clave, el solver queda DESHABILITADO y SRI sigue devolviendo
# bloqueado_captcha (comportamiento previo, sin cambios). Ver services/captcha.py.
TWOCAPTCHA_API_KEY=

# Deployment (Render asigna PORT automáticamente; HOST=0.0.0.0 en prod).
# HOST=0.0.0.0
# PORT=10000
